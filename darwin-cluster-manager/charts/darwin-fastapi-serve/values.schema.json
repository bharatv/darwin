{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "required": [],
    "properties": {
        "flagger": {
            "type": "object",
            "properties": {
                "enabled": { "type": "boolean" },
                "provider": {
                    "type": "string",
                    "enum": ["nginx", "istio"]
                },
                "progressDeadlineSeconds": { "type": "integer" },
                "type": {
                    "type": "string",
                    "enum": ["canary", "immute"]
                },
                "interval": { "type": "string" },
                "threshold": { "type": "integer" },
                "skipAnalysis": { "type": "boolean" },
                "maxWeight": { "type": "integer" },
                "stepWeight": { "type": "integer" },
                "iterations": { "type": "integer" },
                "maxSurge": { "type": ["string", "integer"] },
                "maxUnavailable": { "type": ["string", "integer"] },
                "gateways": {
                    "type": "array",
                    "items": { "type": "string" }
                },
                "metrics": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "interval": { "type": "string" },
                            "thresholdRange": {
                                "type": "object",
                                "properties": {
                                    "min": { "type": "number" },
                                    "max": { "type": "number" }
                                }
                            },
                            "templateRef": {
                                "type": "object",
                                "properties": {
                                    "name": { "type": "string" },
                                    "namespace": { "type": "string" }
                                }
                            }
                        }
                    }
                }
            }
        },
        "hpa": {
            "type": "object",
            "required": [
                "enabled",
                "maxReplicas",
                "cpu",
                "memory"
            ],
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "maxReplicas": {
                    "type": "integer"
                },
                "cpu": {
                    "type": "integer"
                },
                "memory": {
                    "type": "object",
                    "required": [
                        "target",
                        "value"
                    ],
                    "properties": {
                        "target": {
                            "type": "string",
                            "enum": [
                                "Utilization",
                                "Value"
                            ]
                        },
                        "value": {
                            "type": "integer"
                        },
                        "unit": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}
